{
  "name": "bili-music-desktop",
  "private": true,
  "version": "1.1.0-beta.1",
  "main": "main.js",
  "type": "module",
  "author": {
    "name": "zitont",
    "email": "1456492197@qq.com"
  },
  "license": "MIT",
  "description": "哔哩哔哩音乐桌面客户端",
  "repository": {},
  "build": {
    "appId": "bili.music",
    "productName": "Bili Music",
    "directories": {
      "output": "build"
    },
    "buildVersion": "1.1.0-beta.1",
    "win": {
      "icon": "./imgs/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "imgs/icon.ico",
      "uninstallerIcon": "imgs/icon.ico",
      "uninstallDisplayName": "Bili Music 哔哩哔哩音乐",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bili Music",
      "deleteAppDataOnUninstall": false,
      "include": "./scripts/installer.nsh"
    }
  },
  "scripts": {
    "dev": "vite",
    "copy-deps": "node scripts/copy-deps.js",
    "build:vite": "vue-tsc && vite build",
    "build:electron": "electron-builder",
    "preview": "vite preview",
    "electron-forge:start": "electron-forge start",
    "electron-forge:package": "electron-forge package",
    "electron-forge:make": "electron-forge make",
    "electron:start": "nodemon --exec electron . --watch ./ --ext .js,.html,.css,.vue",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder --win --x64",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.13.0",
    "@vueuse/core": "^10.11.1",
    "@vueuse/integrations": "^10.11.1",
    "better-sqlite3": "^12.9.0",
    "naive-ui": "^2.44.1",
    "pinia": "^2.3.1",
    "qrcode": "^1.5.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/publisher-github": "^7.4.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.11.24",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "cross-env": "^7.0.3",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.1.8",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.3",
    "sass": "^1.71.1",
    "typescript": "^5.2.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.7",
    "vitest": "^4.1.5",
    "vue-tsc": "^1.8.27",
    "vuepress-plugin-components": "^2.0.0-rc.31"
  }
}
